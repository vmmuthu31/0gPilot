# ─── 0G Compute ───────────────────────────────────────────────
ZERO_G_API_KEY=
ZERO_G_API_URL=https://compute-network-6.integratenetwork.work/v1/proxy

# ─── 0G Chain ─────────────────────────────────────────────────
NEXT_PUBLIC_0G_RPC_URL=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_0G_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# ─── REQUIRED: Deployer wallet private key (64 hex chars, no 0x prefix) ────────
# openssl rand -hex 32
ZERO_G_PRIVATE_KEY=

# ─── REQUIRED: AES-256 encryption key for 0G storage (min 32 chars) ────────────
# openssl rand -hex 32
STORAGE_ENCRYPTION_KEY=

# ─── Auth ─────────────────────────────────────────────────────
# openssl rand -hex 32
JWT_SECRET=

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/0gpilot

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
