# ─── 0G Compute ───────────────────────────────────────────────
ZERO_G_API_KEY=
ZERO_G_API_URL=https://compute-network-6.integratenetwork.work/v1/proxy

# ─── 0G Chain ─────────────────────────────────────────────────
NEXT_PUBLIC_0G_RPC_URL=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_0G_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# ─── REQUIRED: Deployer wallet private key (64 hex chars, no 0x prefix) ────────
# openssl rand -hex 32
ZERO_G_PRIVATE_KEY=

# ─── REQUIRED: AES-256 encryption key for 0G storage (min 32 chars) ────────────
# openssl rand -hex 32
STORAGE_ENCRYPTION_KEY=

# ─── Auth ─────────────────────────────────────────────────────
# openssl rand -hex 32
JWT_SECRET=

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/0gpilot

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Billing / Credits ─────────────────────────────────────────
# Address that receives on-chain plan payments
NEXT_PUBLIC_ADMIN_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# Plan prices are in 0G (will be converted to wei server-side)
PRO_PLAN_PRICE_OG=10
PRO_PLUS_PLAN_PRICE_OG=50

# Credits granted after successful payment confirmation
PRO_PLAN_CREDITS=5000
PRO_PLUS_PLAN_CREDITS=25000

# Credits debited per workflow generation
WORKFLOW_CREDITS_COST_FREE=10
WORKFLOW_CREDITS_COST_PRO=5

# ─── Smart Contract Registry (fill after running deploy script) ──────────────
# cd src/chains && npx hardhat run scripts/deploy.ts --network zeroG
NEXT_PUBLIC_PROJECT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_EXECUTION_CONTROLLER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_AGENT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ZEROG_PILOT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# ─── Memory Conditioning ──────────────────────────────────────
# Cosine similarity threshold for memory retrieval (0.0 – 1.0, default 0.8)
VECTOR_SIMILARITY_THRESHOLD=0.8
